{
  "name": "clarix",
  "version": "0.1.0",
  "private": true,
  "description": "503B Digital Batch Record & Facility Management Platform",
  "keywords": [
    "503B",
    "batch-records",
    "cgmp",
    "compounding",
    "drizzle",
    "monorepo",
    "nextjs",
    "react-native",
    "supabase",
    "turborepo"
  ],
  "license": "UNLICENSED",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@dotenv-run/cli": "1.3.6",
      "@hookform/resolvers": "5.2.2",
      "@tailwindcss/postcss": "4.2.2",
      "@types/bun": "1.3.11",
      "@types/node": "25.5.0",
      "@types/pg": "8.20.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "better-auth": "1.5.6",
      "class-variance-authority": "0.7.1",
      "clsx": "2.1.1",
      "date-fns": "4.1.0",
      "drizzle-orm": "0.45.1",
      "drizzle-seed": "0.3.1",
      "drizzle-zod": "0.8.3",
      "drizzle-kit": "0.31.10",
      "envin": "1.2.0",
      "framer-motion": "12.38.0",
      "lucide-react": "1.0.1",
      "next": "16.2.1",
      "next-safe-action": "8.1.8",
      "next-themes": "0.4.6",
      "nuqs": "2.8.9",
      "pg": "8.20.0",
      "radix-ui": "1.4.3",
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "react-hook-form": "7.72.0",
      "recharts": "3.3.0",
      "shadcn": "4.1.0",
      "sonner": "2.0.7",
      "tailwindcss": "4.2.2",
      "tailwind-merge": "3.5.0",
      "tsdown": "0.21.4",
      "turbo": "2.8.20",
      "typescript": "6.0.2",
      "zod": "4.3.6",
      "zustand": "5.0.12"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build --affected",
    "clean": "git clean -xdf .turbo node_modules",
    "dev": "turbo dev",
    "db:generate": "turbo generate --filter=@clarix/db",
    "db:migrate": "turbo migrate --filter=@clarix/db",
    "db:push": "turbo push --filter=@clarix/db",
    "db:pull": "turbo pull --filter=@clarix/db",
    "db:seed": "turbo seed --filter=@clarix/db",
    "db:studio": "turbo studio --filter=@clarix/db",
    "format": "oxfmt .",
    "lint": "oxlint .",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@dotenv-run/cli": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "shadcn": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.2.19"
}
