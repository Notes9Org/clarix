# =============================================================================
# Clarix — 503B Digital Batch Record Platform
# =============================================================================
# Copy this file to `.env` and fill in your values.
# Keep this file up-to-date when you add new variables.

# Database (Supabase local via `supabase start`)
DATABASE_URL="postgres://postgres:postgres@127.0.0.1:54332/postgres"
DIRECT_URL="postgres://postgres:postgres@127.0.0.1:54332/postgres"

# Product
PRODUCT_NAME="Clarix"
BASE_URL="http://localhost:3000"

# Next.js public
NEXT_PUBLIC_PRODUCT_NAME="${PRODUCT_NAME}"
NEXT_PUBLIC_BASE_URL="${BASE_URL}"
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54331"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-supabase-anon-key>"

# Auth (Better-Auth)
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="<run: openssl rand -hex 32>"
BETTER_AUTH_ADMIN_EMAIL="admin@clarix.io"
BETTER_AUTH_ADMIN_PASSWORD="<admin-password>"
BETTER_AUTH_ADMINS="<admin-uuid>"

# Supabase (populated by `supabase start`)
SUPABASE_URL="http://127.0.0.1:54331"
SUPABASE_ANON_KEY="<populated-by-supabase-start>"
SUPABASE_SERVICE_ROLE_KEY="<populated-by-supabase-start>"
